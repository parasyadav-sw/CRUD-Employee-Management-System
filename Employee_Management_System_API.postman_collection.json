						"{{baseUrl}}"
					],
					"path": [
						"api",
						"employees"
					],
					"query": [
						{
							"key": "sortBy",
							"value": "salary",
							"description": "Sort target field (name, department, salary, joinDate)"
						},
						{
							"key": "order",
							"value": "desc",
							"description": "asc or desc"
						}
					]
				},
				"description": "Retrieves employee list sorted by salary descending."
			},
			"response": []
		},
		{
